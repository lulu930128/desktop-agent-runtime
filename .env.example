# Copy this file to .env and fill in local settings. .env is ignored by git.

# Default character backend.
KURO_LLM_PROVIDER=openai_llm

# Optional OpenAI settings when you want this project to use GPT instead.
OPENAI_API_KEY=
OPENAI_LLM_API_KEY=
OPENAI_TRANSLATE_MODEL=gpt-4o-mini
OPENAI_LLM_MODEL=gpt-4o
OPENAI_LLM_TEMPERATURE=1.0
ENABLE_OLLAMA_FALLBACK=0
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_TRANSLATE_MODEL=qwen2.5:7b
OPENAI_LLM_INJECT_KEY=1
