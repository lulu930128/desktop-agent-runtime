# Copy this file to .env and fill in local secrets. .env is ignored by git.

# Used by the bridge and as the fallback LLM key.
OPENAI_API_KEY=

# Optional: use a separate key for the character LLM.
OPENAI_LLM_API_KEY=

# Optional launcher overrides.
OPENAI_LLM_MODEL=gpt-4o
OPENAI_LLM_TEMPERATURE=1.0
OPENAI_LLM_INJECT_KEY=1
KURO_LLM_PROVIDER=openai_llm
