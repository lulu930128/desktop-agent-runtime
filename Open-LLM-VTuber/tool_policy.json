{
  "version": 1,
  "default_mode": "blocked",
  "tools": {
    "get_current_time": {
      "mode": "read_only",
      "category": "web"
    },
    "search_web": {
      "mode": "read_only",
      "category": "web"
    },
    "smart_search_web": {
      "mode": "read_only",
      "category": "web"
    },
    "advanced_search_web": {
      "mode": "read_only",
      "category": "web"
    },
    "fetch_content": {
      "mode": "read_only",
      "category": "web",
      "url_args": ["url"],
      "block_private_urls": true
    },
    "list_allowed_roots": {
      "mode": "read_only",
      "category": "filesystem"
    },
    "list_directory": {
      "mode": "read_only",
      "category": "filesystem",
      "path_args": ["path"],
      "allow_hidden": false
    },
    "search_files": {
      "mode": "read_only",
      "category": "filesystem",
      "path_args": ["path"],
      "allow_hidden": false
    },
    "read_text_file": {
      "mode": "read_only",
      "category": "filesystem",
      "path_args": ["path"],
      "allow_hidden": false
    },
    "search_past_conversations": {
      "mode": "read_only",
      "category": "memory"
    },
    "mail.auth_status": {
      "mode": "read_only",
      "category": "mail"
    },
    "mail.auth_start": {
      "mode": "read_only",
      "category": "mail"
    },
    "mail.auth_finish": {
      "mode": "read_only",
      "category": "mail"
    },
    "mail.list_unread": {
      "mode": "read_only",
      "category": "mail",
      "deny_truthy_args": ["include_spam_trash"]
    },
    "mail.search_recent": {
      "mode": "read_only",
      "category": "mail",
      "deny_truthy_args": ["include_spam_trash"]
    },
    "mail.get_message_summary": {
      "mode": "read_only",
      "category": "mail"
    },
    "mail.get_message_detail": {
      "mode": "read_only",
      "category": "mail"
    },
    "mail.daily_brief": {
      "mode": "read_only",
      "category": "mail",
      "deny_truthy_args": ["include_spam_trash"]
    },
    "mail.update_briefing": {
      "mode": "read_only",
      "category": "mail",
      "deny_truthy_args": ["include_spam_trash"]
    },
    "omi.ask": {
      "mode": "read_only",
      "category": "market_intelligence",
      "deny_truthy_args": ["allow_llm", "allow_write"],
      "deny_values": {
        "mode": ["report"]
      }
    }
  },
  "filesystem": {
    "deny_path_patterns": [
      "*.env",
      "*.env.*",
      "*/.env",
      "*/.env.*",
      "*.pem",
      "*.key",
      "*.pfx",
      "*.p12",
      "*id_rsa*",
      "*id_ed25519*",
      "*api_key*",
      "*apikey*",
      "*secret*",
      "*password*",
      "*credential*",
      "*/AppData/Local/Google/Chrome/User Data/*",
      "*/AppData/Local/Microsoft/Edge/User Data/*",
      "*/AppData/Roaming/Mozilla/Firefox/Profiles/*",
      "*/Cookies",
      "*/Login Data"
    ],
    "deny_path_parts": [
      ".git",
      ".ssh",
      ".gnupg",
      "keyrings"
    ]
  },
  "web": {
    "blocked_hostnames": [
      "localhost",
      "127.0.0.1",
      "::1",
      "0.0.0.0"
    ],
    "block_private_networks": true
  }
}
